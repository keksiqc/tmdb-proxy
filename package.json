{
  "name": "tmdb-proxy",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nitro build",
    "dev": "nitro dev",
    "prepare": "nitro prepare && simple-git-hooks",
    "preview": "bun run .output/server/index.mjs",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "ipx": "3.1.1",
    "lint-staged": "16.4.0",
    "nitro": "3.0.260311-beta",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "simple-git-hooks": "2.13.1"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "bun run lint:fix",
    "*": "bun run fmt --no-error-on-unmatched-pattern"
  },
  "packageManager": "bun@1.3.11"
}
