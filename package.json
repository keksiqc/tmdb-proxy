{
  "name": "tmdb-proxy",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nitro build",
    "dev": "nitro dev",
    "prepare": "nitro prepare && simple-git-hooks",
    "preview": "bun run .output/server/index.mjs",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "devDependencies": {
    "@types/bun": "1.3.10",
    "ipx": "3.1.1",
    "lint-staged": "16.3.2",
    "nitro": "3.0.1-alpha.2",
    "oxfmt": "0.36.0",
    "oxlint": "1.51.0",
    "rolldown": "1.0.0-rc.7",
    "simple-git-hooks": "2.13.1"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "bun run lint:fix",
    "*": "bun run fmt --no-error-on-unmatched-pattern"
  },
  "packageManager": "bun@1.3.10"
}
