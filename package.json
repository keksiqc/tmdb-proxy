{
  "private": true,
  "scripts": {
    "build": "nitro build",
    "dev": "nitro dev",
    "prepare": "nitro prepare && simple-git-hooks",
    "preview": "node .output/server/index.mjs",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "devDependencies": {
    "ipx": "^3.1.1",
    "lint-staged": "^16.3.2",
    "nitro": "^3.0.1-alpha.2",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "simple-git-hooks": "^2.13.1"
  },
  "simple-git-hooks": {
    "pre-commit": "bun run lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "bun run lint:fix",
    "*": "bun run fmt"
  },
  "packageManager": "bun@1.3.10"
}
